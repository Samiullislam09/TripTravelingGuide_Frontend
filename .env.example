# Public site URL (Vercel sets this automatically in production).
NEXT_PUBLIC_SITE_URL="https://triptravelingguide.com"

# Dashboard/CMS public API base. When set, the frontend pulls live posts from
# the dashboard's /api/public endpoints; otherwise it serves local sample posts.
# DASHBOARD_API_URL="https://your-dashboard.vercel.app"

# ---------- Supabase (comments + images + shared data) ----------
# Project ref: etuqhwpyfdpkgykexhnb  (Supabase → Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://etuqhwpyfdpkgykexhnb.supabase.co"
# anon/public key — safe in the browser, gated by RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY="paste-anon-public-key"
# service_role key — SERVER ONLY. Bypasses RLS. NEVER prefix with NEXT_PUBLIC,
# never expose to the browser. Used by the comments API route.
SUPABASE_SERVICE_ROLE_KEY="paste-service-role-key"
